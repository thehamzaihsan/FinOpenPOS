# ============================================================
# POS-SY Environment Variables Configuration
# Copy this file to .env.local and fill in your values
# ============================================================

# ============================================================
# SUPABASE
# Get these from your Supabase project settings
# ============================================================

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous/Public Key (safe to expose to frontend)
# Can use either of these names (they're the same key):
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_anon_your_key_here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Supabase Service Role Key (NEVER expose to frontend, server-only)
# Keep this in .env.local, never commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================
# ADMIN ACCOUNT SETUP
# Used during Supabase migration to seed admin user
# Optional - defaults to admin@pos-sy.dev if not set
# ============================================================

ADMIN_EMAIL=admin@pos-sy.dev
ADMIN_NAME=POS-SY Admin

# ============================================================
# APPLICATION CONFIG
# ============================================================

# Environment (development, staging, production)
NODE_ENV=development

# Enable debug logging (true/false)
DEBUG=false

# ============================================================
# OPTIONAL: THIRD-PARTY SERVICES
# ============================================================

# Mixpanel Analytics (optional)
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Sentry Error Tracking (optional)
SENTRY_AUTH_TOKEN=your_sentry_token

# ============================================================
# BUSINESS LOGIC DEFAULTS
# Customize per deployment if needed
# ============================================================

# Default discount settings (percentage)
DEFAULT_MIN_DISCOUNT=0
DEFAULT_MAX_DISCOUNT=20

# Tax percentage (if applicable)
INVOICE_TAX_RATE=0

# Invoice numbering prefix
INVOICE_PREFIX=INV-

# Thermal printer default width (characters)
THERMAL_PRINTER_WIDTH=32

# ============================================================
# IMPORTANT NOTES
# ============================================================

# 1. .env.local is in .gitignore - your secrets are safe locally
# 2. Never commit SUPABASE_SERVICE_ROLE_KEY to git
# 3. NEXT_PUBLIC_* variables are exposed to the browser (don't put secrets there)
# 4. After first setup, admin account is seeded in database
# 5. All environment variables are optional except Supabase ones

# ============================================================
# VERIFICATION CHECKLIST
# ============================================================

# Before running: npm run dev
# [ ] NEXT_PUBLIC_SUPABASE_URL is set
# [ ] NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is set
# [ ] SUPABASE_SERVICE_ROLE_KEY is set (for server operations)
# [ ] Database migration has been applied in Supabase
# [ ] Admin account email is correct (used during migration)
